# Default: normalize text files to LF in repository
* text=auto eol=lf

# Stellaris / Clausewitz text formats
*.txt   text eol=lf
*.yml   text eol=lf
*.mod   text eol=lf
*.asset text eol=lf
*.gui   text eol=lf
*.gfx   text eol=lf
*.shader text eol=lf

# Project scripts / docs
*.py    text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.bat   text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.dds binary
*.tga binary
*.zip binary
*.7z binary
*.exe binary
*.dll binary
*.pdxmesh binary
*.ogg binary
*.wav binary
